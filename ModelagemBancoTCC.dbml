	Subcategoria.CategoriaId > Categoria.CategoriaId [ delete: no action, update: no action ]
}

Ref fk_Produto_SubcategoriaId_Subcategoria {
	Produto.SubcategoriaId > Subcategoria.SubcategoriaId [ delete: no action, update: no action ]
